# TalentIQ Database Configuration
# Local SQLite for development (default): sqlite:///./talentiq.db
# PostgreSQL for production: postgresql://postgres:password@db.supabase.co:5432/postgres
DATABASE_URL=sqlite:///./talentiq.db

# Supabase Storage Configuration
SUPABASE_URL=https://your-supabase-project.supabase.co
SUPABASE_KEY=your-supabase-service-role-key-never-share
SUPABASE_BUCKET=resumes

# Google Gemini API key (Google AI Studio)
# Get one from: https://aistudio.google.com/
GEMINI_API_KEY=your-gemini-api-key
